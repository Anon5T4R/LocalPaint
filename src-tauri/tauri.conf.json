{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalPaint",
  "version": "0.4.0",
  "identifier": "com.localpaint.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1482",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LocalPaint",
        "width": 1240,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "fileAssociations": [
      {
        "ext": ["tpaint"],
        "name": "LocalPaint",
        "description": "Documento do LocalPaint",
        "role": "Editor"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
